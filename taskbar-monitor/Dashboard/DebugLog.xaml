<UserControl x:Class="TaskbarMonitor.Dashboard.DebugLog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,22,28,16" Background="#ffffff">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TitleText" Grid.Row="0" Text="调试日志" FontSize="22" FontWeight="Bold" Foreground="#18181b"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="SubText" Grid.Row="1" Text="实时事件日志和测试工具" FontSize="12"
                           Foreground="#6b6b70" Margin="0,0,0,0"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Padding="24,0,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Actions bar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="ClearBtn" Content="清空" Style="{StaticResource SoftBtn}" Margin="0,0,8,0"/>
                    <Button x:Name="TestBtn" Content="模拟事件" Style="{StaticResource AccentBtn}" Margin="0,0,8,0"/>
                    <CheckBox x:Name="AutoScrollCheck" Content=" 自动滚动" IsChecked="True"
                              Foreground="#6b6b70" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock x:Name="StatusText" Text="服务: --" FontSize="11" Foreground="#939399"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                </StackPanel>

                <!-- Log area -->
                <Border Grid.Row="1" Background="#f8f8fa" CornerRadius="10" Padding="2"
                        BorderBrush="#1a000000" BorderThickness="1" Margin="0,0,0,8">
                    <RichTextBox x:Name="LogBox" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="Transparent" Foreground="#18181b"
                                 BorderThickness="0"/>
                </Border>
            </Grid>
        </Border>

        <!-- Bottom input bar -->
        <Border Grid.Row="2" Padding="24,8,24,16" Background="#ffffff">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="QuickInput" Text="http://127.0.0.1:23400/state"
                         FontFamily="Consolas" FontSize="11"
                         Style="{StaticResource AppTextBox}"
                         VerticalAlignment="Center"/>
                <Button x:Name="SendBtn" Grid.Column="1" Content="GET" Width="70"
                        Style="{StaticResource SoftBtn}" Margin="8,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
