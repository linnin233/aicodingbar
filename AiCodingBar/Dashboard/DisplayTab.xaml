<UserControl x:Class="AiCodingBar.Dashboard.DisplayTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="显示设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="0" Text="自定义任务栏叠加文字的外观和行为" FontSize="12" Foreground="#888888" Margin="0,24,0,12"/>

        <!-- ─ 显示模式 ─ -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="任务栏显示" FontSize="11" FontWeight="Bold" Foreground="#999" Margin="0,12,0,4"/>
            <Separator/>

            <!-- 模式 -->
            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="显示模式" VerticalAlignment="Center"/>
                <ComboBox x:Name="ModeCombo" Grid.Column="1" Width="160" HorizontalAlignment="Left">
                    <ComboBoxItem>compact</ComboBoxItem>
                    <ComboBoxItem>aggregate</ComboBoxItem>
                    <ComboBoxItem>highlight</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 双行模式 -->
            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="双行模式"/>
                    <TextBlock Text="上方聚合摘要 + 下方逐条详情" FontSize="11" Foreground="#888"/>
                </StackPanel>
                <CheckBox x:Name="ShowLine2Check" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
            </Grid>

            <!-- 详情行最大数 -->
            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="第二行最大数"/>
                    <TextBlock Text="超出则截断显示" FontSize="11" Foreground="#888"/>
                </StackPanel>
                <TextBox x:Name="Line2MaxBox" Grid.Column="1" Width="60" HorizontalAlignment="Left"/>
            </Grid>

            <!-- 显示持续时间 -->
            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="显示持续时间" VerticalAlignment="Center"/>
                <CheckBox x:Name="ShowDurationCheck" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
            </Grid>

            <!-- 显示零值 -->
            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="聚合模式显示零值" VerticalAlignment="Center"/>
                <CheckBox x:Name="ShowZeroCheck" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
            </Grid>

            <!-- 自动切换阈值 -->
            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="自动切换阈值"/>
                    <TextBlock Text="会话数超过该值自动切聚合模式" FontSize="11" Foreground="#888"/>
                </StackPanel>
                <TextBox x:Name="ThresholdBox" Grid.Column="1" Width="60" HorizontalAlignment="Left"/>
            </Grid>
        </StackPanel>

        <!-- ─ 字体 ─ -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="字体" FontSize="11" FontWeight="Bold" Foreground="#999" Margin="0,16,0,4"/>
            <Separator/>

            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="字体名称" VerticalAlignment="Center"/>
                <TextBox x:Name="FontNameBox" Grid.Column="1" Width="180" HorizontalAlignment="Left"/>
            </Grid>

            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="字号 (pt)" VerticalAlignment="Center"/>
                <TextBox x:Name="FontSizeBox" Grid.Column="1" Width="60" HorizontalAlignment="Left"/>
            </Grid>

            <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="自动字号"/>
                    <TextBlock Text="根据任务栏高度自动缩放" FontSize="11" Foreground="#888"/>
                </StackPanel>
                <CheckBox x:Name="AutoFontCheck" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
            </Grid>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button x:Name="SaveBtn" Content="保存设置" Width="120" Padding="8,4"
                        Background="#0078D4" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="ResetBtn" Content="恢复默认" Width="120" Padding="8,4"
                        Margin="8,0,0,0" Cursor="Hand"/>
            </StackPanel>

            <TextBlock x:Name="StatusText" FontSize="12" Foreground="#888" Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
